<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Applied at codesign time (bundle.macOS.entitlements). The release build
     signs with the hardened runtime, which blocks microphone capture unless
     this entitlement is granted — without it, audio memos fail silently in
     notarized builds. -->
<plist version="1.0">
<dict>
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Read-only Apple Calendar access for the daily-note events panel
	     (src/calendar.rs); without it the hardened runtime blocks EventKit
	     in notarized builds. -->
	<key>com.apple.security.personal-information.calendars</key>
	<true/>
	<!-- Apple Contacts integration: read-only CNContactStore lookups for
	     person notes. Without this the hardened runtime blocks the contacts
	     permission prompt in notarized builds. -->
	<key>com.apple.security.personal-information.addressbook</key>
	<true/>
	<!-- iCloud Drive document sync (Plan 21) — DELIBERATELY COMMENTED OUT.
	     These are *restricted* entitlements: unlike the capability grants
	     above, codesign only honors them when a provisioning profile that
	     lists them is embedded in the app — signing with them and no profile
	     produces an app that fails to launch. Enabling iCloud on the desktop
	     release therefore needs, once, in the developer portal: (1) an App ID
	     for app.reflect.desktop with the iCloud capability and the container
	     below assigned, (2) a Developer ID provisioning profile for it,
	     embedded by the release script as embedded.provisionprofile, then
	     (3) uncomment this block. The container id must stay byte-identical
	     to the iOS app's (gen/apple entitlements) — it IS the shared folder
	     both apps sync through. Until then `icloud_status` honestly reports
	     unavailable and the settings section explains itself.
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.app.reflect.ios</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.ubiquity-container-identifiers</key>
	<array>
		<string>iCloud.app.reflect.ios</string>
	</array>
	-->
</dict>
</plist>
